# ----- LLM provider: "openai" or "bedrock" -----
LLM_PROVIDER=openai

# ----- OpenAI (used when LLM_PROVIDER=openai) -----
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_GEN_MODEL=gpt-4o-mini

# ----- AWS Bedrock (used when LLM_PROVIDER=bedrock) -----
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_GEN_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ----- Database (PostgreSQL + pgvector) -----
DB_HOST=your-db-host.region.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ragdb
DB_USER=postgres
DB_PASSWORD=your-db-password

# ----- AWS (for S3 storage + SQS ingestion queue) -----
AWS_REGION=us-east-1
# AWS_PROFILE is for LOCAL dev only. On AWS (Fargate), leave unset so the
# IAM task role is used instead. Comment out / remove for deployment.
AWS_PROFILE=your-local-aws-profile
S3_BUCKET=your-s3-bucket-name
QUEUE_URL=https://sqs.region.amazonaws.com/account-id/your-queue-name
